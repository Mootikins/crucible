{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "Lua 5.4"
  },
  "workspace": {
    "library": ["${3rd}/luv/library"],
    "checkThirdParty": false
  },
  "diagnostics": {
    "globals": ["cru", "describe", "it", "before_each", "after_each", "assert", "pending", "inspect"]
  }
}
