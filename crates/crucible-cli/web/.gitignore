# Test artifacts
test-results/
playwright-report/

# Build output
dist/
node_modules/

# Local env
.env.local
.env.*.local

# PWA icons (root .gitignore blanket-ignores *.png as debug artifacts)
!public/*.png

# Committed Playwright visual baselines (re-include past the root *.png ignore).
# These are checked-in golden images for the `stories` project; test-*.png
# outputs live under test-results/ (ignored above).
!e2e/__screenshots__/**/*.png
