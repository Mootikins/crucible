# Crucible ACP Demo Configuration
# Copy to demo-acp-config.toml and set your environment variables.
# Used for recording ACP and delegation demo fixtures.

kiln_path = "./docs"

[llm]
default = "demo"

[llm.providers.demo]
type = "openai"
endpoint = "{env:CRUCIBLE_DEMO_ENDPOINT}"
default_model = "glm-4.7-flash-iq4"
temperature = 0.3
max_tokens = 2048

[chat]
agent_preference = "crucible"

[cli]
show_progress = false
confirm_destructive = true
verbose = false

[permissions]
default = "allow"

[enrichment.provider]
type = "fastembed"
model = "BAAI/bge-small-en-v1.5"
batch_size = 32
dimensions = 384

[enrichment.pipeline]
worker_count = 4
batch_size = 16
max_queue_size = 1000
timeout_ms = 30000
retry_attempts = 3
retry_delay_ms = 1000

# ACP Agent Profiles with Delegation Configuration
[acp.agents.claude]
extends = "claude"
env = { CLAUDE_CONFIG_DIR = "/tmp/crucible-demo-claude" }

[acp.agents.claude.delegation]
enabled = true
max_depth = 1
allowed_targets = ["cursor", "opencode"]

[acp.agents.cursor]
extends = "cursor"

[acp.agents.opencode]
extends = "opencode"
