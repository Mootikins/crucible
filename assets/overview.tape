Output assets/cru-overview.gif

Require cru

Set Shell "bash"
Set FontSize 16
Set Width 1200
Set Height 700
Set Theme "Firewatch"
Set WindowBar Colorful
Set WindowBarSize 40
Set Padding 20
Set TypingSpeed 40ms
Set PlaybackSpeed 2

Type "cru --version && cru stats -C assets/demo-config.toml --no-process"
Enter
Sleep 5s
